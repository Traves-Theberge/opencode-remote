{
  "name": "opencode-remote",
  "version": "1.0.0",
  "description": "OpenCode Remote Control via WhatsApp and Telegram",
  "private": true,
  "type": "module",
  "main": "apps/daemon/src/index.ts",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run typecheck",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.ts\" \"tests/**/*.ts\" \"apps/**/*.ts\" \"packages/**/*.ts\"",
    "start": "npm --workspace @opencode-remote/daemon run start",
    "dev": "npm --workspace @opencode-remote/daemon run dev",
    "cli": "npm --workspace @opencode-remote/cli run start --",
    "tui": "npm --workspace @opencode-remote/tui run start",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:workspaces": "npm --workspace @opencode-remote/daemon run typecheck && npm --workspace @opencode-remote/cli run typecheck && npm --workspace @opencode-remote/bridge run typecheck",
    "test": "tsx --test tests/*.test.ts",
    "test:workspaces": "npm --workspace @opencode-remote/cli run start -- help",
    "verify": "node scripts/verify.mjs"
  },
  "dependencies": {
    "whatsapp-web.js": "^1.26.0",
    "@opencode-ai/sdk": "^1.2.15",
    "better-sqlite3": "^12.6.2",
    "qrcode": "^1.5.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "conf": "^15.1.0",
    "uuid": "^13.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.46.1",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2"
  }
}
